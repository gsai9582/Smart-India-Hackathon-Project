<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Smart Table Tennis Dashboard</title>

  <!-- Chart.js & Tailwind (CDNs) -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    body { font-family: 'Inter', sans-serif; background: #e0f7fa; margin:0; color:#111; overflow-x:hidden; }
    .main { padding: 20px; overflow:auto; position: relative; z-index:0; min-height:100vh; }

    h2.section-title { font-size: 1.6rem; font-weight:700; background: linear-gradient(90deg,#007bff,#00c8ff); -webkit-background-clip:text; -webkit-text-fill-color:transparent; margin-bottom: 16px; }

    .cards { display:flex; flex-wrap:wrap; gap:16px; margin-bottom:28px; }
    .score-card { background:#fff; border-radius:12px; padding:16px; flex:1 1 230px; box-shadow:0 8px 25px rgba(0,0,0,0.08); transition:transform .2s, box-shadow .2s; position:relative; overflow:hidden; }
    .score-card:hover{ transform: translateY(-6px); box-shadow:0 14px 30px rgba(0,0,0,0.12); }
    .card-header{ display:flex; align-items:center; gap:8px; margin-bottom:8px; }
    .card-header h3{ margin:0; font-size:1.05rem; font-weight:600; }

    .dot{ width:12px; height:12px; border-radius:999px; display:inline-block; animation:pulse 1.6s infinite; }
    .dot.blue{ background:#007bff; } .dot.red{ background:#dc3545; }
    @keyframes pulse{ 0%,100%{ transform:scale(1); opacity:1; } 50%{ transform:scale(1.45); opacity:0.6; } }

    .progress-bar{ width:100%; background:#eee; border-radius:10px; height:12px; margin-top:8px; overflow:hidden; }
    .progress-fill{ height:100%; border-radius:10px; transition: width .45s ease-in-out; width:0%; }
    .progress-fill.blue{ background:#007bff; } .progress-fill.red{ background:#dc3545; }

    table{ width:100%; border-collapse:collapse; margin-top:16px; background:#fff; border-radius:8px; overflow:hidden; box-shadow:0 8px 20px rgba(2,6,23,0.06); }
    th, td{ padding:12px 14px; border-bottom:1px solid #eee; text-align:center; font-size:0.95rem; }
    thead th{ background:transparent; font-weight:600; }
    tbody tr:hover{ background:#f8fafc; transform: none; }

    /* Background canvas */
    .dashboard-bg { position:fixed; top:0; left:0; width:100%; height:100%; z-index:-1; overflow:hidden; background: linear-gradient(135deg,#e0f7fa 0%, #fff 100%); }
    #courtCanvas{ width:100%; height:100%; display:block; }

    /* Dropdown (3-dot) */
    .dropdown { position:absolute; top:18px; right:18px; z-index:70; }
    .dropdown button{ font-size:1.25rem; background:none; border:none; cursor:pointer; color:#111; padding:6px; border-radius:6px; }
    .dropdown-menu{ position:absolute; right:0; margin-top:8px; width:180px; background:white; border-radius:10px; box-shadow:0 8px 30px rgba(2,6,23,0.12); display:none; overflow:hidden; }
    .dropdown-menu a{ display:block; padding:10px 12px; text-decoration:none; color:#111; font-size:0.95rem; }
    .dropdown-menu a:hover{ background:#f3f4f6; }

    /* Hidden slide-out menu */
    #hiddenMenu{ position:fixed; top:0; left:-280px; width:280px; height:100%; background:#111827; color:white; z-index:80; transition:left .28s ease; display:flex; flex-direction:column; }
    #hiddenMenu h2{ font-size:1.2rem; font-weight:700; padding:18px; border-bottom:1px solid #2b2f36; margin:0; }
    #hiddenMenu a{ padding:14px 18px; text-decoration:none; color:#e6eef8; border-bottom:1px solid #1f2937; transition:background .15s; font-size:0.95rem; }
    #hiddenMenu a:hover{ background:#1f2937; }

    /* Hamburger */
    #menuBtnHamburger{ position:fixed; top:16px; left:16px; font-size:1.6rem; background:none; border:none; color:#111; z-index:90; cursor:pointer; padding:8px; border-radius:8px; }

    /* Small responsiveness */
    @media (max-width:720px){
      .cards{ gap:12px; }
      .score-card{ flex:1 1 100%; }
      #hiddenMenu{ width:220px; }
    }
  </style>
</head>
<body>

  <!-- Background canvas -->
  <div class="dashboard-bg" aria-hidden="true">
    <canvas id="courtCanvas"></canvas>
  </div>

  <!-- Hamburger (left) -->
  <button id="menuBtnHamburger" aria-label="Togg
